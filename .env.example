DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Keep sqlite locally, or set DJANGO_DATABASE_ENGINE=postgres with the compose postgres profile.
DJANGO_DATABASE_ENGINE=sqlite
SQLITE_DATABASE_NAME=db.sqlite3
POSTGRES_DB=campfireconnections
POSTGRES_USER=campfire
POSTGRES_PASSWORD=campfire
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Security toggles for production
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=true

# API behavior
DJANGO_API_PAGE_SIZE=50
DJANGO_API_THROTTLE_USER=1000/day
DJANGO_API_THROTTLE_ANON=100/day

# Third-party integrations
GOOGLE_API_KEY=
